#!/usr/bin/env bash
set -euo pipefail

IMAGE="timeisonymyside"
HEALTH_URL="http://localhost:8080/health/liveness"
APP_URL="http://localhost:8080"
ADMIN_URL="http://localhost:8080/login"
MAIL_URL="http://localhost:8025"

# ── 1. Check Docker ───────────────────────────────────────────────────────────
if ! command -v docker &>/dev/null; then
  echo ""
  echo "ERROR: Docker is not installed or not in PATH."
  echo "Install Docker Desktop from https://www.docker.com/products/docker-desktop"
  echo ""
  exit 1
fi

if ! docker info &>/dev/null; then
  echo ""
  echo "ERROR: Docker is not running. Please start Docker Desktop and try again."
  echo ""
  exit 1
fi

# ── 2. Ensure image exists ────────────────────────────────────────────────────
if ! docker image inspect "$IMAGE" &>/dev/null; then
  if [ -f "$(dirname "$0")/timeisonymyside.tar.gz" ]; then
    echo "Loading pre-built image from timeisonymyside.tar.gz ..."
    docker load < "$(dirname "$0")/timeisonymyside.tar.gz"
  else
    echo "No pre-built image found. Building from source (requires internet, ~5-8 min) ..."
    docker compose -f "$(dirname "$0")/docker-compose.yml" build
  fi
fi

# ── 3. Start containers ───────────────────────────────────────────────────────
echo "Starting containers ..."
docker compose -f "$(dirname "$0")/docker-compose.yml" up -d

# ── 4. Wait for health ────────────────────────────────────────────────────────
echo -n "Waiting for app to be ready "
READY=false
for i in $(seq 1 60); do
  if curl -sf "$HEALTH_URL" &>/dev/null; then
    echo " ready!"
    READY=true
    break
  fi
  echo -n "."
  sleep 1
done

if [ "$READY" = false ]; then
  echo ""
  echo "ERROR: App did not become healthy within 60 seconds."
  echo "Check logs with:  docker compose logs app"
  exit 1
fi

# ── 5. Open browser tabs ──────────────────────────────────────────────────────
open_browser() {
  if command -v open &>/dev/null; then        # macOS
    open "$1"
  elif command -v xdg-open &>/dev/null; then  # Linux
    xdg-open "$1"
  fi
}

open_browser "$APP_URL"
sleep 0.5
open_browser "$ADMIN_URL"
sleep 0.5
open_browser "$MAIL_URL"

# ── 6. Summary ────────────────────────────────────────────────────────────────
echo ""
echo "┌─────────────────────────────────────────────────────────────┐"
echo "│  TimeIsOnMySide — Demo is running                           │"
echo "├─────────────────────────────────────────────────────────────┤"
echo "│  Booking page   http://localhost:8080                       │"
echo "│  Admin login    http://localhost:8080/login                 │"
echo "│  Mail UI        http://localhost:8025                       │"
echo "├─────────────────────────────────────────────────────────────┤"
echo "│  Admin:  username=admin   password=Admin1234!               │"
echo "└─────────────────────────────────────────────────────────────┘"
echo ""
echo "To stop:   docker compose down"
echo "To reset:  docker compose down -v"
echo ""
